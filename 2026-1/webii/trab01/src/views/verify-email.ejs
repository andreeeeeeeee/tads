<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />
    <title>MarketMVP | Verificar e-mail</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              display: ["Space Grotesk", "sans-serif"],
              body: ["Plus Jakarta Sans", "sans-serif"],
            },
            colors: {
              brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#43361A", 900: "#251E10" },
              accent: { 500: "#0A7D7A", 600: "#075F5D" },
              coral: { 500: "#E66A4E", 600: "#C85339" },
            },
          },
        },
      };
    </script>
    <style>
      .grid-bg {
        background-image: radial-gradient(#d9ceaa 0.8px, transparent 0.8px), radial-gradient(#d9ceaa 0.8px, #f8f7f2 0.8px);
        background-size: 28px 28px;
        background-position: 0 0, 14px 14px;
      }
    </style>
  </head>
  <body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="index.html" class="font-display text-xl font-bold">MarketMVP</a>
          <a href="login.html" class="rounded-full border border-brand-300 px-4 py-2 text-sm font-semibold hover:bg-brand-100">Ir para login</a>
        </div>
      </header>

      <main class="mx-auto flex max-w-7xl items-center justify-center px-4 py-10 sm:px-6 lg:px-8">
        <section class="w-full max-w-md rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <h1 class="font-display text-3xl font-bold">Verifique seu e-mail</h1>
          <p class="mt-1 text-sm text-brand-700">
            Enviamos um código de <strong><%= ttlMinutes %> minutos</strong> de validade para o seu e-mail. Digite-o abaixo para ativar a conta e poder entrar.
          </p>
          <% if (sent) { %>
          <p class="mt-4 rounded-xl border border-accent-500/30 bg-accent-500/10 px-4 py-3 text-sm font-medium text-accent-800">
            Enviamos as instruções por e-mail (em desenvolvimento sem SMTP, o código aparece no terminal do servidor). O código vale por <%= ttlMinutes %> minutos — confira também a pasta de spam.
          </p>
          <% } %>
          <% if (mailError) { %>
          <p class="mt-4 rounded-xl border border-coral-500/40 bg-coral-500/10 px-4 py-3 text-sm font-medium text-coral-800">
            Não foi possível enviar o e-mail automaticamente. Verifique o console do servidor (modo dev) ou configure SMTP. Você pode usar &quot;Reenviar código&quot; após configurar.
          </p>
          <% } %>
          <% if (typeof error !== 'undefined' && error) { %>
          <div class="mt-4 rounded-xl border border-coral-500/40 bg-coral-500/10 px-4 py-3 text-sm font-medium text-coral-800" role="alert">
            <%= error %>
          </div>
          <% } %>

          <form class="mt-5 space-y-4" method="post" action="/verify-email">
            <label class="block">
              <span class="mb-1 block text-sm font-medium">E-mail</span>
              <input type="email" name="email" value="<%= email %>" required autocomplete="email" class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium">Código (6 dígitos)</span>
              <input type="text" name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autocomplete="one-time-code" placeholder="000000" class="w-full rounded-xl border border-brand-300 px-4 py-2.5 font-mono text-lg tracking-widest outline-none ring-coral-500 focus:ring" />
            </label>
            <button type="submit" class="w-full rounded-xl bg-brand-900 px-4 py-2.5 font-semibold text-brand-50 hover:bg-brand-800">Confirmar e-mail</button>
          </form>

          <form class="mt-4 border-t border-brand-200 pt-4" method="post" action="/verify-email/resend">
            <input type="hidden" name="email" value="<%= email %>" />
            <p class="text-xs text-brand-600">Código expirou ou não chegou?</p>
            <button type="submit" class="mt-2 w-full rounded-xl border border-brand-300 px-4 py-2.5 text-sm font-semibold hover:bg-brand-100">Reenviar código</button>
          </form>
        </section>
      </main>
    </div>
  </body>
</html>
