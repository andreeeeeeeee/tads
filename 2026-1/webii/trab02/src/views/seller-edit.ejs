<!doctype html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light" />
  <title>MarketMVP | Editar Perfil (Vendedor)</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
    rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ["Space Grotesk", "sans-serif"],
            body: ["Plus Jakarta Sans", "sans-serif"],
          },
          colors: {
            brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#43361A", 900: "#251E10" },
            accent: { 500: "#0A7D7A", 600: "#075F5D" },
            coral: { 500: "#E66A4E", 600: "#C85339" },
          },
        },
      },
    };
  </script>
  <style>
    .grid-bg {
      background-image: radial-gradient(#d9ceaa 0.8px, transparent 0.8px), radial-gradient(#d9ceaa 0.8px, #f8f7f2 0.8px);
      background-size: 28px 28px;
      background-position: 0 0, 14px 14px;
    }
  </style>
</head>

<body class="font-body bg-brand-50 text-brand-900">
  <div class="min-h-screen grid-bg">
    <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href="/index" class="font-display text-xl font-bold">MarketMVP</a>
        <nav class="hidden gap-5 text-sm font-medium md:flex">
          <a href="/index" class="hover:text-accent-600">Início</a>
          <form action="/logout" method="post" class="inline">
            <button type="submit"
              class="cursor-pointer border-0 bg-transparent p-0 text-sm font-medium hover:text-accent-600">Sair</button>
          </form>
        </nav>
      </div>
    </header>
    <main class="max-w-xl mx-auto py-8">
      <h1 class="text-2xl font-bold mb-6">Editar Perfil (Vendedor)</h1>
      <% if (typeof errors !=='undefined' && errors && errors.length) { %>
        <ul class="bg-red-100 text-red-700 p-3 rounded mb-4 list-disc list-inside text-sm space-y-1">
          <% errors.forEach(function(e) { %>
            <li>
              <%= e %>
            </li>
            <% }); %>
        </ul>
        <% } %>
          <form action="/vendedor/editar" method="post" class="bg-white p-6 rounded shadow space-y-4">
            <div>
              <label class="block mb-1 font-medium">Nome da loja</label>
              <input type="text" name="loja_nome" value="<%= user.loja_nome || '' %>" required
                class="w-full border rounded px-3 py-2" />
            </div>
            <div>
              <label class="block mb-1 font-medium">Descrição da loja/vendedor</label>
              <textarea name="loja_descricao" required
                class="w-full border rounded px-3 py-2"><%= user.loja_descricao || '' %></textarea>
            </div>
            <div>
              <label class="block mb-1 font-medium">Telefone/Contato comercial</label>
              <input type="text" name="telefone" value="<%= user.telefone || '' %>" required
                class="w-full border rounded px-3 py-2" />
            </div>
            <div>
              <label class="block mb-1 font-medium">Cidade</label>
              <input type="text" name="cidade" value="<%= user.cidade || '' %>" required
                class="w-full border rounded px-3 py-2" />
            </div>
            <div>
              <label for="seller-estado" class="block mb-1 font-medium">Estado</label>
              <% const
                UFS=['AC','AL','AP','AM','BA','CE','DF','ES','GO','MA','MT','MS','MG','PA','PB','PR','PE','PI','RJ','RN','RS','RO','RR','SC','SP','SE','TO'];
                const selectedUf=(user.estado || '' ).toUpperCase(); %>
                <select id="seller-estado" name="estado" required class="w-full border rounded px-3 py-2 bg-white">
                  <option value="" <%=selectedUf ? '' : 'selected' %>>Selecione...</option>
                  <% UFS.forEach(function(uf) { %>
                    <option value="<%= uf %>" <%=selectedUf===uf ? 'selected' : '' %>><%= uf %>
                    </option>
                    <% }); %>
                </select>
            </div>
            <div>
              <label class="block mb-1 font-medium">Categorias/Tipos de produto</label>
              <input type="text" name="loja_categorias" value="<%= user.loja_categorias || '' %>" required
                class="w-full border rounded px-3 py-2" />
            </div>
            <button type="submit" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2 rounded">Salvar</button>
            <a href="/vendedor/perfil" class="ml-4 text-brand-700 hover:underline">Cancelar</a>
          </form>
    </main>
  </div>
</body>

</html>