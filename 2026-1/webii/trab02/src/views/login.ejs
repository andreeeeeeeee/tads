<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />
    <title>MarketMVP | Entrar</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              display: ["Space Grotesk", "sans-serif"],
              body: ["Plus Jakarta Sans", "sans-serif"],
            },
            colors: {
              brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#43361A", 900: "#251E10" },
              accent: { 500: "#0A7D7A", 600: "#075F5D" },
              coral: { 500: "#E66A4E", 600: "#C85339" },
            },
          },
        },
      };
    </script>
    <style>
      .grid-bg {
        background-image: radial-gradient(#d9ceaa 0.8px, transparent 0.8px), radial-gradient(#d9ceaa 0.8px, #f8f7f2 0.8px);
        background-size: 28px 28px;
        background-position: 0 0, 14px 14px;
      }
    </style>
  </head>
  <body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="index.html" class="font-display text-xl font-bold">MarketMVP</a>
          <nav class="flex items-center gap-3 text-sm font-semibold">
            <a href="signup.html" class="rounded-full border border-brand-300 px-4 py-2 hover:bg-brand-100">Criar conta</a>
          </nav>
        </div>
      </header>

      <main class="mx-auto flex max-w-7xl items-center justify-center px-4 py-10 sm:px-6 lg:px-8">
        <section class="w-full max-w-md rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <h1 class="font-display text-3xl font-bold">Bem-vindo de volta</h1>
          <p class="mt-1 text-sm text-brand-700">Use o e-mail cadastrado e sua senha. O perfil (comprador, vendedor ou admin) vem da sua conta.</p>
          <% if (typeof verified !== 'undefined' && verified) { %>
          <p class="mt-4 rounded-xl border border-accent-500/30 bg-accent-500/10 px-4 py-3 text-sm font-medium text-accent-800">
            E-mail verificado com sucesso. Entre com sua senha.
          </p>
          <% } %>
          <% if (typeof alreadyVerified !== 'undefined' && alreadyVerified) { %>
          <p class="mt-4 rounded-xl border border-brand-200 bg-brand-50 px-4 py-3 text-sm font-medium text-brand-800">
            Este e-mail já está verificado. Use sua senha para entrar.
          </p>
          <% } %>
          <% if (typeof deactivated !== 'undefined' && deactivated) { %>
          <p class="mt-4 rounded-xl border border-brand-300 bg-brand-100 px-4 py-3 text-sm font-medium text-brand-800">
            Sua sessão foi encerrada porque a conta foi desativada ou não está mais ativa.
          </p>
          <% } %>
          <% if (typeof error !== 'undefined' && error) { %>
          <div class="mt-4 rounded-xl border border-coral-500/40 bg-coral-500/10 px-4 py-3 text-sm font-medium text-coral-800" role="alert">
            <p><%= error %></p>
            <% if (typeof verifyEmailLink !== 'undefined' && verifyEmailLink) { %>
            <p class="mt-2"><a href="<%= verifyEmailLink %>" class="font-semibold text-accent-700 underline hover:text-accent-600">Abrir página de verificação de e-mail</a></p>
            <% } %>
          </div>
          <% } %>
          <form class="mt-5 space-y-4" method="post" action="/login">
            <input type="hidden" name="next" value="<%= form.next %>" />
            <label class="block">
              <span class="mb-1 block text-sm font-medium">Email</span>
              <input type="email" name="email" value="<%= form.email %>" required autocomplete="email" placeholder="you@example.com" class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium">Senha</span>
              <input type="password" name="password" required autocomplete="current-password" placeholder="********" class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>
            <button type="submit" class="w-full rounded-xl bg-brand-900 px-4 py-2.5 font-semibold text-brand-50 hover:bg-brand-800">Entrar</button>
          </form>
          <p class="mt-4 text-center text-sm text-brand-700">Novo no marketplace? <a href="signup.html" class="font-semibold text-accent-600">Crie sua conta</a></p>
        </section>
      </main>
    </div>
  </body>
</html>
