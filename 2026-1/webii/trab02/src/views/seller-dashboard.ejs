<!doctype html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light" />
  <title>MarketMVP | Painel do vendedor</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
    rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ["Space Grotesk", "sans-serif"],
            body: ["Plus Jakarta Sans", "sans-serif"],
          },
          colors: {
            brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#43361A", 900: "#251E10" },
            accent: { 500: "#0A7D7A", 600: "#075F5D" },
            coral: { 500: "#E66A4E", 600: "#C85339" },
          },
        },
      },
    };
  </script>
  <style>
    .grid-bg {
      background-image: radial-gradient(#d9ceaa 0.8px, transparent 0.8px), radial-gradient(#d9ceaa 0.8px, #f8f7f2 0.8px);
      background-size: 28px 28px;
      background-position: 0 0, 14px 14px;
    }
  </style>
</head>

<body class="font-body bg-brand-50 text-brand-900">
  <div class="min-h-screen grid-bg">
    <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href="/index" class="font-display text-xl font-bold">MarketMVP</a>
        <nav class="hidden gap-5 text-sm font-medium md:flex">
          <a href="/index" class="hover:text-accent-600">Início</a>
          <form action="/logout" method="post" class="inline">
            <button type="submit"
              class="cursor-pointer border-0 bg-transparent p-0 text-sm font-medium hover:text-accent-600">Sair</button>
          </form>
        </nav>
        <button class="rounded-xl bg-coral-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-coral-600">+ Novo
          anúncio</button>
      </div>
    </header>

    <main class="max-w-4xl mx-auto py-8 px-4">
      <h1 class="text-2xl font-bold mb-6">Painel do Vendedor</h1>

      <% if (typeof success !=='undefined' && success) { %>
        <div class="mb-4 rounded border border-accent-500 bg-accent-500/10 px-4 py-2 text-sm text-accent-600">
          <%= success %>
        </div>
        <% } %>
          <% if (typeof error !=='undefined' && error) { %>
            <div class="mb-4 rounded border border-coral-500 bg-coral-500/10 px-4 py-2 text-sm text-coral-600">
              <%= error %>
            </div>
            <% } %>

              <section class="mb-8">
                <h2 class="text-xl font-semibold mb-2">Cadastrar novo produto</h2>
                <form action="/produtos/cadastrar" method="post" enctype="multipart/form-data"
                  class="space-y-4 bg-white p-4 rounded shadow" id="form-cadastrar-produto">
                  <div>
                    <label class="block mb-1 font-medium">Nome</label>
                    <input type="text" name="nome" required class="w-full border rounded px-3 py-2" />
                  </div>
                  <div>
                    <label class="block mb-1 font-medium">Descrição</label>
                    <textarea name="descricao" required class="w-full border rounded px-3 py-2"></textarea>
                  </div>
                  <div>
                    <label class="block mb-1 font-medium">Categoria</label>
                    <input type="text" name="categoria" required class="w-full border rounded px-3 py-2" />
                  </div>
                  <div>
                    <label class="block mb-1 font-medium">Preço</label>
                    <input type="number" name="preco" step="0.01" required class="w-full border rounded px-3 py-2" />
                  </div>
                  <div>
                    <label class="block mb-1 font-medium">Estoque</label>
                    <input type="number" name="estoque" required class="w-full border rounded px-3 py-2" />
                  </div>
                  <div>
                    <label class="block mb-1 font-medium">Imagens do produto <span class="text-xs text-brand-700">(até 8
                        imagens, máx. 5MB cada — JPEG, PNG, WebP ou GIF)</span></label>
                    <input type="file" name="images" id="cadastro-images"
                      accept="image/jpeg,image/png,image/webp,image/gif" multiple required class="block mt-1" />
                    <p class="mt-1 text-xs text-brand-700">Selecione qual será a foto principal. Caso não escolha, a
                      primeira foto enviada será destacada.</p>
                    <div id="cadastro-images-preview" class="mt-3 grid grid-cols-2 sm:grid-cols-4 gap-3"></div>
                    <input type="hidden" name="main_index" id="cadastro-main-index" value="0" />
                  </div>
                  <button type="submit" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2 rounded">Cadastrar
                    Produto</button>
                </form>
                <script>
                  (function () {
                    var input = document.getElementById('cadastro-images');
                    var preview = document.getElementById('cadastro-images-preview');
                    var hidden = document.getElementById('cadastro-main-index');
                    if (!input || !preview || !hidden) return;
                    input.addEventListener('change', function () {
                      preview.innerHTML = '';
                      hidden.value = '0';
                      var files = Array.from(input.files || []);
                      files.forEach(function (file, idx) {
                        var url = URL.createObjectURL(file);
                        var wrap = document.createElement('label');
                        wrap.className = 'cursor-pointer relative block rounded border-2 overflow-hidden ' +
                          (idx === 0 ? 'border-accent-500' : 'border-brand-200');
                        wrap.innerHTML =
                          '<img src="' + url + '" class="h-24 w-full object-cover">' +
                          '<span class="absolute top-1 left-1 bg-white/90 rounded px-1 text-[10px] font-bold flex items-center gap-1">' +
                          '<input type="radio" name="main_radio" value="' + idx + '" ' + (idx === 0 ? 'checked' : '') + '> Principal' +
                          '</span>';
                        preview.appendChild(wrap);
                      });
                      preview.querySelectorAll('input[type=radio]').forEach(function (radio) {
                        radio.addEventListener('change', function () {
                          hidden.value = radio.value;
                          preview.querySelectorAll('label').forEach(function (l, i) {
                            l.classList.toggle('border-accent-500', String(i) === radio.value);
                            l.classList.toggle('border-brand-200', String(i) !== radio.value);
                          });
                        });
                      });
                    });
                  })();
                </script>
              </section>

              <section>
                <h2 class="text-xl font-semibold mb-2">Seus produtos</h2>
                <% if (produtos && produtos.length> 0) { %>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <% produtos.forEach(function(produto) { %>
                      <% var imagensProduto=produto.imagens || []; %>
                        <div class="bg-white rounded shadow p-4 flex flex-col">
                          <% if (produto.imageUrl) { %>
                            <img src="<%= produto.imageUrl %>" alt="Imagem do produto"
                              class="w-full h-40 object-cover rounded mb-2" />
                            <% } else { %>
                              <div
                                class="w-full h-40 mb-2 flex items-center justify-center rounded bg-brand-100 text-sm text-brand-700">
                                Sem imagem principal</div>
                              <% } %>
                                <h3 class="font-bold text-lg mb-1">
                                  <%= produto.name %>
                                </h3>
                                <p class="mb-1">
                                  <%= produto.description %>
                                </p>
                                <div class="text-sm text-brand-700 mb-1">Categoria: <%= produto.category %>
                                </div>
                                <div class="text-sm mb-1">Preço: R$ <%= produto.price.toFixed(2) %>
                                </div>
                                <div class="text-sm mb-1">Estoque: <%= produto.stock %>
                                </div>

                                <div class="mt-3 border-t border-brand-100 pt-3">
                                  <div class="flex items-center justify-between mb-2">
                                    <h4 class="text-sm font-semibold">Galeria (<%= imagensProduto.length %>/8)</h4>
                                    <a href="/produtos/<%= produto.id %>"
                                      class="text-xs text-accent-600 hover:underline">Ver página do produto</a>
                                  </div>
                                  <% if (imagensProduto.length> 0) { %>
                                    <ul class="grid grid-cols-4 gap-2">
                                      <% imagensProduto.forEach(function(img) { %>
                                        <li
                                          class="relative rounded border <%= img.isMain ? 'border-accent-500 ring-1 ring-accent-500' : 'border-brand-200' %>">
                                          <img src="<%= img.imageUrl %>" alt="Foto"
                                            class="aspect-square w-full object-cover rounded" />
                                          <% if (img.isMain) { %>
                                            <span
                                              class="absolute bottom-0 left-0 right-0 bg-accent-500/90 text-[10px] font-bold uppercase text-white py-0.5 text-center">Principal</span>
                                            <% } %>
                                              <div class="mt-1 flex flex-col gap-1">
                                                <% if (!img.isMain) { %>
                                                  <form
                                                    action="/produtos/<%= produto.id %>/imagens/<%= img.id %>/principal"
                                                    method="post">
                                                    <button type="submit"
                                                      class="w-full rounded bg-brand-100 text-[11px] font-semibold py-0.5 hover:bg-brand-200">Tornar
                                                      principal</button>
                                                  </form>
                                                  <% } %>
                                                    <% if (imagensProduto.length> 1) { %>
                                                      <form
                                                        action="/produtos/<%= produto.id %>/imagens/<%= img.id %>?_method=DELETE"
                                                        method="post"
                                                        onsubmit="return confirm('Remover esta foto do produto?');">
                                                        <button type="submit"
                                                          class="w-full rounded bg-coral-500/10 text-[11px] font-semibold text-coral-600 py-0.5 hover:bg-coral-500/20">Remover</button>
                                                      </form>
                                                      <% } %>
                                              </div>
                                        </li>
                                        <% }); %>
                                    </ul>
                                    <% } else { %>
                                      <p class="text-xs text-brand-700">Nenhuma foto cadastrada.</p>
                                      <% } %>

                                        <% if (imagensProduto.length < 8) { %>
                                          <form action="/produtos/<%= produto.id %>/imagens" method="post"
                                            enctype="multipart/form-data" class="mt-3 flex flex-col gap-2">
                                            <label class="text-xs font-semibold">Adicionar mais fotos</label>
                                            <input type="file" name="images"
                                              accept="image/jpeg,image/png,image/webp,image/gif" multiple required
                                              class="text-xs" />
                                            <button type="submit"
                                              class="self-start rounded bg-accent-500 px-3 py-1 text-xs font-semibold text-white hover:bg-accent-600">Enviar
                                              fotos</button>
                                          </form>
                                          <% } %>
                                </div>

                                <div class="text-xs text-brand-400 mt-3">Cadastrado em: <%=
                                    produto.createdAt.toLocaleString() %>
                                </div>
                        </div>
                        <% }) %>
                  </div>
                  <% } else { %>
                    <p>Você ainda não cadastrou produtos.</p>
                    <% } %>
              </section>
    </main>
  </div>
</body>

</html>