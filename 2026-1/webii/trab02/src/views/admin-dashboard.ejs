<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />
    <title>MarketMVP | Painel administrativo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              display: ["Space Grotesk", "sans-serif"],
              body: ["Plus Jakarta Sans", "sans-serif"],
            },
            colors: {
              brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#43361A", 900: "#251E10" },
              accent: { 500: "#0A7D7A", 600: "#075F5D" },
              coral: { 500: "#E66A4E", 600: "#C85339" },
            },
          },
        },
      };
    </script>
    <style>
      .grid-bg {
        background-image: radial-gradient(#d9ceaa 0.8px, transparent 0.8px), radial-gradient(#d9ceaa 0.8px, #f8f7f2 0.8px);
        background-size: 28px 28px;
        background-position: 0 0, 14px 14px;
      }
    </style>
  </head>
  <body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="index.html" class="font-display text-xl font-bold">MarketMVP</a>
          <nav class="hidden gap-5 text-sm font-medium md:flex">
            <a href="index.html" class="hover:text-accent-600">Início</a>
            <form action="/logout" method="post" class="inline">
              <button type="submit" class="cursor-pointer border-0 bg-transparent p-0 text-sm font-medium hover:text-accent-600">Sair</button>
            </form>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
        <% const rolePt = { admin: 'Administrador', comprador: 'Comprador', vendedor: 'Vendedor' }; %>
        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Controle global da plataforma</p>
              <h1 class="mt-1 font-display text-3xl font-bold">Painel administrativo</h1>
              <p class="mt-2 max-w-2xl text-sm text-brand-700">Acompanhe contas cadastradas, identifique perfis com risco operacional e desative acessos quando necessário.</p>
            </div>
            <div class="flex flex-col gap-2 items-end">
              <div class="rounded-2xl bg-brand-100 px-4 py-3 text-sm font-semibold text-brand-800">
                Administrador: <%= adminSession.email %>
              </div>
              <a href="/logs" class="mt-2 inline-block rounded-lg border border-accent-500 px-3 py-1.5 text-xs font-semibold text-accent-600 hover:bg-accent-500/10">Ver logs de auditoria</a>
            </div>
          </div>
          <% if (flashOk) { %>
          <p class="mt-4 rounded-xl border border-accent-500/30 bg-accent-500/10 px-4 py-3 text-sm font-medium text-accent-800">Alteração salva com sucesso.</p>
          <% } %>
          <% if (flashError) { %>
          <p class="mt-4 rounded-xl border border-coral-500/40 bg-coral-500/10 px-4 py-3 text-sm font-medium text-coral-800"><%= flashError %></p>
          <% } %>
          <div class="mt-5 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl bg-brand-100 p-4">
              <p class="text-xs font-semibold uppercase tracking-wider">Contas totais</p>
              <p class="mt-2 font-display text-3xl font-bold"><%= stats.total %></p>
            </div>
            <div class="rounded-2xl bg-brand-100 p-4">
              <p class="text-xs font-semibold uppercase tracking-wider">Contas ativas</p>
              <p class="mt-2 font-display text-3xl font-bold"><%= stats.active %></p>
            </div>
            <div class="rounded-2xl bg-brand-100 p-4">
              <p class="text-xs font-semibold uppercase tracking-wider">Contas inativas</p>
              <p class="mt-2 font-display text-3xl font-bold"><%= stats.inactive %></p>
            </div>
          </div>
        </section>

        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <div>
            <h2 class="font-display text-2xl font-bold">Lista de contas</h2>
            <p class="mt-1 text-sm text-brand-700">Visualize compradores, vendedores e administradores. Usuários inativos não podem fazer login.</p>
          </div>

          <div class="mt-4 overflow-x-auto rounded-2xl border border-brand-200">
            <table class="min-w-full text-left text-sm">
              <thead class="bg-brand-100 text-brand-800">
                <tr>
                  <th class="px-4 py-3 font-semibold">Conta</th>
                  <th class="px-4 py-3 font-semibold">Perfil</th>
                  <th class="px-4 py-3 font-semibold">E-mail</th>
                  <th class="px-4 py-3 font-semibold">Cadastro</th>
                  <th class="px-4 py-3 font-semibold">Status</th>
                  <th class="px-4 py-3 font-semibold">Ações</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-brand-200 bg-white">
                <% if (users.length === 0) { %>
                <tr>
                  <td colspan="6" class="px-4 py-6 text-center text-brand-600">Nenhum usuário cadastrado.</td>
                </tr>
                <% } %>
                <% users.forEach(function (u) { %>
                <tr>
                  <td class="px-4 py-3 font-semibold"><%= u.name %></td>
                  <td class="px-4 py-3"><%= rolePt[u.role] %></td>
                  <td class="px-4 py-3"><%= u.email %></td>
                  <td class="px-4 py-3 text-brand-700"><%= u.created_at %></td>
                  <td class="px-4 py-3">
                    <% if (u.active) { %>
                    <span class="rounded-full bg-accent-500/10 px-2 py-1 text-xs font-semibold text-accent-600">Ativa</span>
                    <% } else { %>
                    <span class="rounded-full bg-brand-200 px-2 py-1 text-xs font-semibold text-brand-800">Inativa</span>
                    <% } %>
                  </td>
                  <td class="px-4 py-3">
                    <% if (u.id === adminSession.id) { %>
                    <span class="text-xs text-brand-600">Sua conta</span>
                    <% } else if (u.active) { %>
                    <form method="post" action="/admin/users/<%= u.id %>/active" class="inline">
                      <input type="hidden" name="active" value="0" />
                      <button type="submit" class="rounded-lg bg-coral-500 px-3 py-1.5 text-xs font-semibold text-white hover:bg-coral-600">Desativar</button>
                    </form>
                    <% } else { %>
                    <form method="post" action="/admin/users/<%= u.id %>/active" class="inline">
                      <input type="hidden" name="active" value="1" />
                      <button type="submit" class="rounded-lg border border-brand-300 px-3 py-1.5 text-xs font-semibold hover:bg-brand-100">Reativar</button>
                    </form>
                    <% } %>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>