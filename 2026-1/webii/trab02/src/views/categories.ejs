<!doctype html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light" />
  <title>MarketMVP | Categorias</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
    rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ["Space Grotesk", "sans-serif"],
            body: ["Plus Jakarta Sans", "sans-serif"],
          },
          colors: {
            brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#43361A", 900: "#251E10" },
            accent: { 500: "#0A7D7A", 600: "#075F5D" },
            coral: { 500: "#E66A4E", 600: "#C85339" },
          },
        },
      },
    };
  </script>
  <style>
    .grid-bg {
      background-image: radial-gradient(#d9ceaa 0.8px, transparent 0.8px), radial-gradient(#d9ceaa 0.8px, #f8f7f2 0.8px);
      background-size: 28px 28px;
      background-position: 0 0, 14px 14px;
    }
  </style>
</head>

<body class="font-body bg-brand-50 text-brand-900">
  <div class="min-h-screen grid-bg">
    <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href="/index" class="font-display text-xl font-bold">MarketMVP</a>
        <nav class="hidden gap-5 text-sm font-medium md:flex">
          <a href="/index" class="hover:text-accent-600">Início</a>
          <% if (currentUser && currentUser.role==='comprador' ) { %>
            <a href="cart" class="hover:text-accent-600">Carrinho</a>
            <a href="orders" class="hover:text-accent-600">Pedidos</a>
            <% } %>
              <% if (currentUser && currentUser.role==='vendedor' ) { %>
                <a href="seller-dashboard" class="hover:text-accent-600">Painel do vendedor</a>
                <% } %>
                  <% if (currentUser && currentUser.role==='admin' ) { %>
                    <a href="admin-dashboard" class="hover:text-accent-600">Painel admin</a>
                    <% } %>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
      <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
        <h1 class="font-display text-3xl font-bold">Navegue pelas categorias</h1>
        <p class="mt-1 text-sm text-brand-700">
          <% if (selectedCategory) { %>
            Mostrando produtos da categoria <strong><%= selectedCategory %></strong>.
            <a href="/categories" class="text-accent-600 hover:underline">Limpar filtro</a>
          <% } else { %>
            Explore produtos por categoria e refine sua busca.
          <% } %>
        </p>

        <% if (categorias && categorias.length > 0) { %>
          <div class="mt-4 flex flex-wrap gap-2">
            <a href="/categories"
               class="rounded-full border px-4 py-2 text-sm font-semibold transition <%= selectedCategory ? 'border-brand-300 hover:bg-brand-100' : 'border-accent-500 bg-accent-500 text-white' %>">
              Todas
              <span class="ml-1 text-xs opacity-75">(<%= categorias.reduce(function(a, c) { return a + c.count; }, 0) %>)</span>
            </a>
            <% categorias.forEach(function(cat) { %>
              <% const isActive = selectedCategory && cat.name.toLowerCase() === selectedCategory.toLowerCase(); %>
              <a href="/categories?categoria=<%= encodeURIComponent(cat.name) %>"
                 class="rounded-full border px-4 py-2 text-sm font-semibold transition <%= isActive ? 'border-accent-500 bg-accent-500 text-white' : 'border-brand-300 hover:bg-brand-100' %>">
                <%= cat.name %>
                <span class="ml-1 text-xs opacity-75">(<%= cat.count %>)</span>
              </a>
            <% }); %>
          </div>
        <% } else { %>
          <p class="mt-4 text-sm text-brand-700">Nenhuma categoria cadastrada ainda.</p>
        <% } %>
      </section>

      <section>
        <div class="mb-4 flex items-end justify-between">
          <h2 class="font-display text-2xl font-bold">
            <% if (selectedCategory) { %>
              Produtos em <%= selectedCategory %>
            <% } else { %>
              Todos os produtos
            <% } %>
          </h2>
          <span class="text-sm text-brand-700"><%= produtos.length %> resultado<%= produtos.length === 1 ? '' : 's' %></span>
        </div>

        <% if (produtos && produtos.length > 0) { %>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <% produtos.forEach(function(produto) { %>
              <article class="rounded-2xl border border-brand-200 bg-white p-4 shadow-sm flex flex-col">
                <% if (produto.imageUrl) { %>
                  <img src="<%= produto.imageUrl.startsWith('/') ? produto.imageUrl : ('/uploads/' + produto.imageUrl) %>"
                       alt="<%= produto.name %>"
                       class="mb-3 h-40 w-full object-cover rounded-lg border border-brand-100" />
                <% } else { %>
                  <div class="mb-3 flex h-40 items-center justify-center rounded-lg bg-brand-100 text-sm text-brand-700">Sem imagem</div>
                <% } %>
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-600"><%= produto.category %></p>
                <h3 class="mt-1 font-display text-lg font-bold"><%= produto.name %></h3>
                <p class="mt-1 line-clamp-2 text-sm text-brand-700"><%= produto.description %></p>
                <div class="mt-3 flex items-center justify-between">
                  <span class="font-bold text-coral-600">R$ <%= produto.price.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></span>
                  <a href="/produtos/<%= produto.id %>" class="rounded-lg border border-brand-300 px-3 py-1.5 text-sm font-semibold hover:bg-brand-100">Ver</a>
                </div>
              </article>
            <% }); %>
          </div>
        <% } else { %>
          <div class="rounded-2xl border border-dashed border-brand-300 bg-white p-8 text-center text-brand-700">
            <% if (selectedCategory) { %>
              Nenhum produto encontrado em <strong><%= selectedCategory %></strong>.
            <% } else { %>
              Nenhum produto cadastrado ainda.
            <% } %>
          </div>
        <% } %>
      </section>
    </main>
  </div>
</body>

</html>