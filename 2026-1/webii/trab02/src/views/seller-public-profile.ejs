<!doctype html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light" />
  <title>MarketMVP | <%= vendedor ? (vendedor.loja_nome || vendedor.name) : 'Vendedor não encontrado' %>
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
    rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ["Space Grotesk", "sans-serif"],
            body: ["Plus Jakarta Sans", "sans-serif"],
          },
          colors: {
            brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#43361A", 900: "#251E10" },
            accent: { 500: "#0A7D7A", 600: "#075F5D" },
            coral: { 500: "#E66A4E", 600: "#C85339" },
          },
        },
      },
    };
  </script>
  <style>
    .grid-bg {
      background-image: radial-gradient(#d9ceaa 0.8px, transparent 0.8px), radial-gradient(#d9ceaa 0.8px, #f8f7f2 0.8px);
      background-size: 28px 28px;
      background-position: 0 0, 14px 14px;
    }
  </style>
</head>

<body class="font-body bg-brand-50 text-brand-900">
  <div class="min-h-screen grid-bg">
    <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href="/index" class="flex items-center gap-3">
          <div class="h-9 w-9 rounded-lg bg-gradient-to-br from-coral-500 to-brand-500"></div>
          <div>
            <p class="font-display text-xl font-bold tracking-tight">MarketMVP</p>
            <p class="text-xs text-brand-700">compre, anuncie e gerencie em um só lugar</p>
          </div>
        </a>
        <nav class="hidden gap-5 text-sm font-medium md:flex">
          <a href="/index" class="hover:text-accent-600">Início</a>
          <a href="/categories" class="hover:text-accent-600">Categorias</a>
        </nav>
        <div class="flex items-center gap-2">
          <% if (currentUser) { %>
            <% if (currentUser.role==='vendedor' ) { %>
              <a href="/vendedor/perfil" class="hidden text-sm text-brand-700 sm:inline"
                title="<%= currentUser.name %>">
                <%= currentUser.name %>
              </a>
              <% } else if (currentUser.role==='comprador' ) { %>
                <a href="/comprador/perfil" class="hidden text-sm text-brand-700 sm:inline"
                  title="<%= currentUser.name %>">
                  <%= currentUser.name %>
                </a>
                <% } %>
                  <form action="/logout" method="post" class="inline">
                    <button type="submit"
                      class="rounded-full border border-brand-300 px-4 py-2 text-sm font-semibold hover:bg-brand-100">Sair</button>
                  </form>
                  <% } else { %>
                    <a href="/login"
                      class="rounded-full border border-brand-300 px-4 py-2 text-sm font-semibold hover:bg-brand-100">Entrar</a>
                    <a href="/signup"
                      class="rounded-full bg-brand-900 px-4 py-2 text-sm font-semibold text-brand-50 hover:bg-brand-800">Criar
                      conta</a>
                    <% } %>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
      <% if (!vendedor) { %>
        <section class="rounded-3xl border border-brand-200 bg-white p-8 text-center shadow-sm">
          <h1 class="font-display text-2xl font-bold">Vendedor não encontrado</h1>
          <p class="mt-2 text-brand-700">O perfil solicitado não existe ou está indisponível.</p>
          <a href="/index"
            class="mt-4 inline-block rounded-xl bg-brand-900 px-5 py-2.5 font-semibold text-brand-50 hover:bg-brand-800">Voltar
            ao início</a>
        </section>
        <% } else { %>
          <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm md:p-8">
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
              <div class="flex items-start gap-4">
                <div
                  class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-coral-500 to-brand-500 font-display text-2xl font-bold text-white">
                  <%= (vendedor.loja_nome || vendedor.name || '?' ).trim().charAt(0).toUpperCase() %>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Perfil do vendedor</p>
                  <h1 class="font-display text-3xl font-bold leading-tight">
                    <%= vendedor.loja_nome || vendedor.name %>
                  </h1>
                  <p class="text-sm text-brand-700">Responsável: <%= vendedor.name %>
                  </p>
                </div>
              </div>
              <div class="flex flex-col items-start gap-1 text-sm md:items-end">
                <span
                  class="rounded-full bg-brand-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-700">
                  <%= produtos.length %> produto<%= produtos.length===1 ? '' : 's' %>
                </span>
                <% if (currentUser && currentUser.id===vendedor.id) { %>
                  <a href="/vendedor/editar" class="text-xs font-semibold text-accent-600 hover:underline">Editar minhas
                    informações</a>
                  <% } %>
              </div>
            </div>

            <div class="mt-6 grid gap-4 sm:grid-cols-2">
              <div class="rounded-2xl border border-brand-200 bg-brand-50/60 p-4">
                <h2 class="text-xs font-bold uppercase tracking-wider text-brand-600">Sobre a loja</h2>
                <p class="mt-2 whitespace-pre-line text-sm text-brand-800">
                  <%= vendedor.loja_descricao && vendedor.loja_descricao.trim() ? vendedor.loja_descricao
                    : 'Este vendedor ainda não cadastrou uma descrição.' %>
                </p>
              </div>
              <div class="rounded-2xl border border-brand-200 bg-brand-50/60 p-4">
                <h2 class="text-xs font-bold uppercase tracking-wider text-brand-600">Contato e localização</h2>
                <ul class="mt-2 space-y-1 text-sm text-brand-800">
                  <li><strong>Telefone/Contato:</strong>
                    <%= vendedor.telefone || '—' %>
                  </li>
                  <li><strong>Cidade:</strong>
                    <%= vendedor.cidade || '—' %>
                  </li>
                  <li><strong>Estado:</strong>
                    <%= vendedor.estado || '—' %>
                  </li>
                  <li><strong>Categorias:</strong>
                    <%= vendedor.loja_categorias || '—' %>
                  </li>
                </ul>
              </div>
            </div>
          </section>

          <section class="mt-8">
            <div class="mb-4 flex items-end justify-between">
              <h2 class="font-display text-2xl font-bold">Produtos deste vendedor</h2>
            </div>

            <% if (produtos.length===0) { %>
              <div class="rounded-2xl border border-dashed border-brand-300 bg-white p-8 text-center text-brand-700">
                Este vendedor ainda não publicou produtos.
              </div>
              <% } else { %>
                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                  <% produtos.forEach(function(produto) { %>
                    <% var capa=(produto.imagens && produto.imagens.length> 0) ?
                      (produto.imagens.find(function(i){return i.isMain;}) || produto.imagens[0]).imageUrl :
                      produto.imageUrl; %>
                      <article class="rounded-2xl border border-brand-200 bg-white p-4 shadow-sm flex flex-col">
                        <% if (capa) { %>
                          <img src="<%= capa %>" alt="<%= produto.name %>"
                            class="mb-3 h-40 w-full rounded-lg border border-brand-100 object-cover" />
                          <% } else { %>
                            <div
                              class="mb-3 flex h-40 items-center justify-center rounded-lg bg-brand-100 text-sm text-brand-700">
                              Sem imagem</div>
                            <% } %>
                              <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">
                                <%= produto.category %>
                              </p>
                              <h3 class="mt-1 font-display text-lg font-bold">
                                <%= produto.name %>
                              </h3>
                              <p class="mt-1 line-clamp-2 text-sm text-brand-700">
                                <%= produto.description %>
                              </p>
                              <div class="mt-3 flex items-center justify-between">
                                <span class="font-bold text-coral-600">R$ <%= produto.price.toLocaleString('pt-BR', {
                                    minimumFractionDigits: 2 }) %></span>
                                <a href="/produtos/<%= produto.id %>"
                                  class="rounded-lg border border-brand-300 px-3 py-1.5 text-sm font-semibold hover:bg-brand-100">Ver</a>
                              </div>
                      </article>
                      <% }); %>
                </div>
                <% } %>
          </section>
          <% } %>
    </main>

    <footer class="mt-8 border-t border-brand-200/80 bg-white/80">
      <div
        class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-3 px-4 py-5 text-sm text-brand-700 sm:px-6 lg:px-8">
        <p>Template conceitual para testar o fluxo de um MVP de marketplace.</p>
        <a href="/index" class="hover:text-accent-600">Voltar ao início</a>
      </div>
    </footer>
  </div>
</body>

</html>